APP_HOST=
APP_PORT=

# Uses your existing postgres container credentials
POSTGRES_ADMIN_URL=

# Dedicated application DB name
POSTGRES_DB=

# Application DB URL (uses dedicated DB)
POSTGRES_URL=

# Dragonfly uses Redis protocol
DRAGONFLY_URL=

# PASETO local key secret (any long string; hashed to 32 bytes internally)
PASETO_LOCAL_KEY=

# XChaCha20-Poly1305 key secret (any long string; hashed to 32 bytes internally)
XCHACHA20_KEY=

# Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=

# Security hardening
REQUEST_BODY_LIMIT_BYTES=
RATE_LIMIT_REQUESTS_PER_MINUTE=
ACCESS_TOKEN_TTL_MINUTES=
REFRESH_TOKEN_TTL_DAYS=

# Filesystem location for optimized profile avatars
AVATAR_STORAGE_DIR=