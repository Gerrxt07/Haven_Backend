FROM rust:latest

# Install lld for faster linking and cargo-watch for hot reload
RUN apt-get update \
    && apt-get install -y --no-install-recommends lld libvips-tools \
    && rm -rf /var/lib/apt/lists/*

# Install cargo-watch to automatically restart the server when code changes
RUN cargo install cargo-watch

WORKDIR /app

ENV RUSTFLAGS="-C link-arg=-fuse-ld=lld"

# When the container starts, watch for source changes and restart cargo run automatically.
# Ignore runtime output files to avoid restart loops.
CMD ["cargo", "watch", "-i", "backend-events.log", "-i", "storage", "-x", "run"]
